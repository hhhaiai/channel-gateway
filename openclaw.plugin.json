{
  "id": "channel-gateway",
  "activation": {
    "onStartup": true
  },
  "enabledByDefault": false,
  "contracts": {
    "gatewayMethodDispatch": [
      "authenticated-request"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "databasePath": {
        "type": "string",
        "minLength": 1,
        "default": ".channel-gateway/channel-gateway.sqlite"
      },
      "ackTtlMs": {
        "type": "integer",
        "minimum": 1,
        "default": 300000
      },
      "failedTtlMs": {
        "type": "integer",
        "minimum": 1,
        "default": 86400000
      },
      "correlationTtlMs": {
        "type": "integer",
        "minimum": 1,
        "default": 30000
      },
      "maxCorrelationEntries": {
        "type": "integer",
        "minimum": 1,
        "default": 10000
      },
      "bodyLimitBytes": {
        "type": "integer",
        "minimum": 1,
        "default": 1048576
      },
      "sseHeartbeatMs": {
        "type": "integer",
        "minimum": 1,
        "default": 15000
      },
      "sseMaxQueue": {
        "type": "integer",
        "minimum": 1,
        "default": 1000
      },
      "deliveryPollMs": {
        "type": "integer",
        "minimum": 1,
        "default": 1000
      },
      "deliveryMaxAttempts": {
        "type": "integer",
        "minimum": 1,
        "default": 5
      },
      "deliveryLeaseMs": {
        "type": "integer",
        "minimum": 1000,
        "default": 60000
      },
      "deliveryMaxConcurrency": {
        "type": "integer",
        "minimum": 1,
        "maximum": 256
      },
      "deliveryMaxConcurrencyPerAccount": {
        "type": "integer",
        "minimum": 1,
        "maximum": 64,
        "default": 2
      },
      "links": {
        "type": "array",
        "default": [],
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "endpoints"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "endpoints": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "channel",
                  "conversationId",
                  "to"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "channel": {
                    "type": "string",
                    "minLength": 1
                  },
                  "accountId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "conversationId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "to": {
                    "type": "string",
                    "minLength": 1
                  },
                  "receive": {
                    "type": "boolean"
                  },
                  "send": {
                    "type": "boolean"
                  },
                  "threadId": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
